{
  "name": "@syntaxname/verdictci",
  "version": "0.1.1",
  "description": "Fail pull requests when AI behavior regresses.",
  "keywords": [
    "ai",
    "llm",
    "evals",
    "ci",
    "github-actions",
    "rag",
    "agents",
    "promptfoo",
    "testing"
  ],
  "author": "syntaxname",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "verdictci": "bin/verdictci.js"
  },
  "files": [
    "bin/",
    "dist/",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "SECURITY.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/syntax-dot/verdict-cli.git"
  },
  "bugs": {
    "url": "https://github.com/syntax-dot/verdict-cli/issues"
  },
  "homepage": "https://github.com/syntax-dot/verdict-cli#readme",
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "pnpm build:tsc && node scripts/build-package.mjs",
    "build:tsc": "tsc --project packages/core/tsconfig.json --noEmit false && tsc --project packages/cli/tsconfig.json --noEmit false",
    "docs:check": "node scripts/docs-check.mjs",
    "lint": "biome check .",
    "package:smoke": "node scripts/package-smoke.mjs",
    "prepack": "pnpm build",
    "test": "vitest run",
    "test:e2e": "vitest run packages/cli/test",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "verdictci": "tsx packages/cli/src/index.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.7",
    "@types/node": "^24.10.1",
    "esbuild": "^0.28.1",
    "promptfoo": "^0.121.17",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.13"
  },
  "dependencies": {
    "commander": "14.0.2",
    "yaml": "2.9.0",
    "zod": "4.4.3"
  }
}
